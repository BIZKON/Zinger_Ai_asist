# ═══════════════════════════════════════════
# PersonalAI Sergiy — минимальный .env для запуска
# ═══════════════════════════════════════════
#
# 1. Скопируй:  cp .env.dev.example .env
# 2. Заполни BOT_TOKEN и ANTHROPIC_API_KEY
# 3. Запусти:   docker compose -f docker-compose.dev.yml up --build

# ── ОБЯЗАТЕЛЬНО (без них бот не запустится) ──
BOT_TOKEN=                        # @BotFather → /newbot → скопировать токен

# ── LLM (нужен хотя бы один) ──
OPENAI_API_KEY=                   # platform.openai.com → API Keys (GPT-4o)
ANTHROPIC_API_KEY=                # console.anthropic.com → API Keys (Claude)

# ── База данных (не меняй для локалки) ──
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=personalai
POSTGRES_USER=personalai
POSTGRES_PASSWORD=changeme

# ── Redis (не меняй для локалки) ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Остальное (опционально, бот работает и без них) ──
# GEMINI_API_KEY=                 # бесплатный, ускоряет простые ответы
# DEEPGRAM_API_KEY=               # для голосовых сообщений
# ELEVENLABS_API_KEY=             # для голосовых ответов
# YANDEX_WEATHER_KEY=             # для погоды в дайджесте
# PERPLEXITY_API_KEY=             # для /search и /research

# ── Настройки приложения ──
ENVIRONMENT=development
LOG_LEVEL=INFO
DEFAULT_PERSONA=sergiy
RATE_LIMIT_PER_MINUTE=30
