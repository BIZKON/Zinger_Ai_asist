# ── Telegram ──────────────────────────────────────────
BOT_TOKEN=                        # @BotFather → /newbot
WEBHOOK_URL=https://your-domain.ru/webhook
ADMIN_USER_IDS=                   # comma-separated telegram IDs

# ── База данных (Timeweb DBaaS) ───────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=personalai
POSTGRES_USER=personalai
POSTGRES_PASSWORD=changeme

# ── Redis ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Supabase Storage (S3) ────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=             # только на сервере

# ── LLM каскад ───────────────────────────────────────
# Для развёртывания в РФ — основной YandexGPT (работает без ограничений).
# Anthropic/OpenAI блокируют запросы из России.
YANDEX_GPT_API_KEY=               # Api-Key от сервисного аккаунта Yandex Cloud
YANDEX_GPT_FOLDER_ID=             # b1g... (Folder ID из Yandex Cloud Console)
ANTHROPIC_API_KEY=                # Claude Sonnet (если VPS не в РФ)
OPENAI_API_KEY=                   # GPT-4o (если VPS не в РФ)
GEMINI_API_KEY=                   # Gemini Flash — простые интенты
OPENROUTER_API_KEY=               # резервный прокси-шлюз

# ── Голос ─────────────────────────────────────────────
ELEVENLABS_API_KEY=               # TTS V3
DEEPGRAM_API_KEY=                 # STT Nova-2 RU

# ── Телефония ─────────────────────────────────────────
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=
VOXIMPLANT_APP_ID=

# ── Контекст (погода/пробки) ──────────────────────────
YANDEX_WEATHER_KEY=
YANDEX_MAPS_KEY=

# ── Поиск ─────────────────────────────────────────────
PERPLEXITY_API_KEY=

# ── Медиа/OCR ─────────────────────────────────────────
YANDEX_VISION_KEY=
GOOGLE_VISION_KEY=                # резерв

# ── 1С (Зингер Логистика) ─────────────────────────────
ONE_C_BASE_URL=                   # через Cloudflare Tunnel
ONE_C_USERNAME=api_personalai
ONE_C_PASSWORD=

# ── Оплата ────────────────────────────────────────────
YUKASSA_SHOP_ID=
YUKASSA_SECRET_KEY=

# ── Персонаж по умолчанию ─────────────────────────────
DEFAULT_PERSONA=sergiy
DEFAULT_VOICE_ID=Maxim

# ── Мониторинг ────────────────────────────────────────
SENTRY_DSN=                       # https://xxx@sentry.io/yyy

# ── Rate Limiting ─────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Приложение ────────────────────────────────────────
ENVIRONMENT=development           # development | production
LOG_LEVEL=INFO
